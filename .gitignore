node_modules/

# Build output (generated by vite/tsup before publish)
dist/

# Environment and secrets
.env
.env.*
!.env.example

# Local npm auth (often contains _authToken — never commit)
.npmrc

# Keys and certificates
*.pem
*.key
*.p12
*.pfx
*.keystore
id_rsa
*.mobileprovision

# Logs and debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*

# OS
.DS_Store
Thumbs.db

# Test / coverage
coverage/
.nyc_output/
playwright-report/
test-results/

# TypeScript
*.tsbuildinfo

# IDE (optional local overrides)
.idea/
.vscode/*
!.vscode/extensions.json
