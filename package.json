{
  "name": "playwright-page-agent",
  "version": "0.1.0",
  "description": "Write your Playwright E2E tests in plain English and let an AI agent execute them.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && tsup",
    "build:packages": "vite build && tsup",
    "prepublishOnly": "bun run build",
    "release": "changeset publish"
  },
  "keywords": ["playwright", "page-agent", "e2e", "ai", "testing"],
  "license": "MIT",
  "peerDependencies": {
    "@playwright/test": ">=1.50.0",
    "page-agent": ">=1.6.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "page-agent": "^1.6.0",
    "@types/node": "^22.0.0",
    "@changesets/cli": "^2.27.0",
    "tsup": "^8.4.0",
    "typescript": "~5.9.3",
    "vite": "^6.0.0"
  }
}
